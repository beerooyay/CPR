# CPR Environment Variables
# Copy this to .env and fill in your actual values

# ESPN Fantasy Basketball (blaize's FBA league)
ESPN_LEAGUE_ID=2058537017

# Firebase (for service account)
FIREBASE_PROJECT_ID=cpr-app-54c15
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_actual_private_key_here\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@cpr-app-54c15.iam.gserviceaccount.com

# Optional APIs
SPORTRADAR_API_KEY=your_sportradar_key_if_you_have_one
OPENROUTER_API_KEY=your_openrouter_key_for_ai_features

# Email (optional)
SENDGRID_API_KEY=your_sendgrid_key_if_using_email
